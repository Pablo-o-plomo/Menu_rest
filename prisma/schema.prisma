generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  manager
  viewer
}

enum PlannedChangeStatus {
  draft
  approved
  active
  cancelled
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  passwordHash String
  role      UserRole @default(viewer)
  createdAt DateTime @default(now())

  snapshots PriceSnapshot[]
  reports   SalesReport[]
  plans     PlannedPriceChange[]
}

model Restaurant {
  id        String   @id @default(cuid())
  name      String
  city      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  menuItems      MenuItem[]
  priceSnapshots PriceSnapshot[]
  salesReports   SalesReport[]
  plannedChanges PlannedPriceChange[]
}

model MenuItem {
  id            String @id @default(cuid())
  restaurantId  String
  externalCode  String?
  article       String
  name          String
  groupName     String?
  priceListName String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  snapshotItems SnapshotItem[]
  salesItems    SalesReportItem[]
  plannedChanges PlannedPriceChange[]

  @@unique([restaurantId, article])
}

model PriceSnapshot {
  id               String   @id @default(cuid())
  restaurantId     String
  snapshotDate     DateTime
  uploadedAt       DateTime @default(now())
  fileName         String
  comment          String?
  uploadedByUserId String

  restaurant       Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  uploadedByUser   User @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  items            SnapshotItem[]

  @@index([restaurantId, snapshotDate])
}

model SnapshotItem {
  id              String   @id @default(cuid())
  snapshotId      String
  menuItemId      String
  article         String
  name            String
  groupName       String?
  priceListName   String?
  salePrice       Decimal  @db.Decimal(12, 2)
  costPrice       Decimal  @db.Decimal(12, 2)
  markupPercent   Decimal  @db.Decimal(7, 2)
  marginPercent   Decimal  @db.Decimal(7, 2)
  foodCostPercent Decimal  @db.Decimal(7, 2)
  createdAt       DateTime @default(now())

  snapshot        PriceSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([menuItemId])
}

model SalesReport {
  id               String   @id @default(cuid())
  restaurantId     String
  startDate        DateTime
  endDate          DateTime
  uploadedAt       DateTime @default(now())
  fileName         String
  uploadedByUserId String

  restaurant       Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  uploadedByUser   User @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  items            SalesReportItem[]
}

model SalesReportItem {
  id                    String   @id @default(cuid())
  salesReportId         String
  menuItemId            String
  article               String
  name                  String
  groupName             String?
  quantitySold          Decimal  @db.Decimal(12, 3)
  totalRevenue          Decimal  @db.Decimal(12, 2)
  averageSalePrice      Decimal  @db.Decimal(12, 2)
  costPrice             Decimal  @db.Decimal(12, 2)
  totalCost             Decimal  @db.Decimal(12, 2)
  grossProfit           Decimal  @db.Decimal(12, 2)
  actualFoodCostPercent Decimal  @db.Decimal(7, 2)
  actualMarginPercent   Decimal  @db.Decimal(7, 2)
  actualMarkupPercent   Decimal  @db.Decimal(7, 2)

  report                SalesReport @relation(fields: [salesReportId], references: [id], onDelete: Cascade)
  menuItem              MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
}

model PlannedPriceChange {
  id                      String @id @default(cuid())
  restaurantId            String
  menuItemId              String
  currentPrice            Decimal @db.Decimal(12, 2)
  plannedPrice            Decimal @db.Decimal(12, 2)
  currentCostPrice        Decimal @db.Decimal(12, 2)
  currentFoodCostPercent  Decimal @db.Decimal(7, 2)
  projectedFoodCostPercent Decimal @db.Decimal(7, 2)
  currentMarginPercent    Decimal @db.Decimal(7, 2)
  projectedMarginPercent  Decimal @db.Decimal(7, 2)
  plannedStartDate        DateTime
  reason                  String
  status                  PlannedChangeStatus @default(draft)
  createdByUserId         String
  createdAt               DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  createdByUser User @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
}
